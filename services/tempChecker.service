[Unit]
Description=The services that check the temperature and controll the fans

[Service]
ExecStart=/home/sneer/smart_mirror/.venv/bin/python3 -u /home/sneer/smart_mirror/scripts/tempControl.py
WorkingDirectory=/home/sneer/smart_mirror
StandardOutput=inherit
StandardError=inherit
Restart=always
User=sneer

[Install]
WantedBy=multi-user.target 
